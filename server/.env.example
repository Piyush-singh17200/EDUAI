# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eduai

# AI & APIs
GOOGLE_GENERATIVE_AI_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-1.5-flash
GEMINI_MAX_OUTPUT_TOKENS=900
GEMINI_TEMPERATURE=0.35
GEMINI_PROMPT_MAX_CHARS=12000
GEMINI_TIMEOUT_MS=18000
GEMINI_THINKING_BUDGET=0
GITHUB_TOKEN=your_github_token_here
LINKEDIN_API_KEY=your_linkedin_api_key_here

# JWT
JWT_SECRET=your_jwt_secret_key_here

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Client URL
CLIENT_URL=http://localhost:3000

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
